<% content_for :meta_title, "#{@player.full_name} - Fantasy Forecast" %>
<% content_for :meta_description, "#{@player.full_name} fantasy football stats, rankings, and news. Get the latest forecast and performance data for your FPL decisions." %>
<% content_for :head do %>
  <%= player_structured_data(@player) %>
<% end %>

<!-- Back Link -->
<%= link_to root_path(position: @player.position), class: "inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-950" do %>
  <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
  </svg>
  Back to Rankings
<% end %>

<!-- Player Header -->
<div class="mt-6 flex items-start gap-6">
  <%= render PlayerAvatarComponent.new(player: @player, size: :large) %>

  <div class="flex-1">
    <h1 class="text-2xl font-semibold text-zinc-950"><%= @player.full_name %></h1>
    <div class="text-sm text-zinc-500 mt-1">
      <p class="flex items-center gap-1.5">
        <%= render TeamBadgeComponent.new(team: @player.team, size: 16) %>
        <%= @player.team&.name %>
      </p>
      <p class="mt-1"><%= @player.position.capitalize %></p>
    </div>

    <% if @player.news.present? %>
      <div class="mt-3 rounded-lg bg-red-400/10 px-3 py-2">
        <p class="text-sm text-red-700"><%= @player.news %></p>
      </div>
    <% end %>
  </div>
</div>

<!-- Top Section: Fixture & Form -->
<div class="mt-8 flex flex-wrap items-start gap-8">
  <% if @upcoming_match %>
    <div>
      <h2 class="text-base/6 font-semibold text-zinc-950">Next Fixture</h2>
      <div class="mt-4">
        <%= render FixtureComponent.new(match: @upcoming_match, player: @player) %>
      </div>
    </div>
  <% end %>

  <div>
    <h2 class="text-base/6 font-semibold text-zinc-950">Recent Form</h2>
    <% if @performances.any? %>
      <div class="mt-4">
        <%= render FormComponent.new(scores: @form_scores) %>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-zinc-500">No performance data available yet.</p>
    <% end %>
  </div>
</div>

<!-- Forecast -->
<div class="mt-8">
  <h2 class="text-base/6 font-semibold text-zinc-950">Forecast</h2>
  <% if @forecast %>
    <div class="mt-4 rounded-lg bg-zinc-100 p-4">
      <p class="font-medium text-zinc-950 flex items-center gap-2">
        <span class="text-xl"><%= @forecast[:tier][:symbol] %></span>
        <% if @forecast[:rank] %>
          #<%= @forecast[:rank] %> <%= @player.position.capitalize %>
        <% end %>
      </p>
      <% if @forecast[:explanation].present? %>
        <p class="text-md text-zinc-700 leading-relaxed mt-3"><%= @forecast[:explanation] %></p>
      <% end %>
    </div>
  <% else %>
    <p class="mt-4 text-sm text-zinc-500">No forecast available.</p>
  <% end %>
</div>
